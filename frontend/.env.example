# Copy to .env.local and fill in your deployed addresses (printed by the deploy scripts).
# All are public — they are baked into the client bundle.

NEXT_PUBLIC_CHAIN_ID=1301                       # Unichain Sepolia (where the hook lives)
NEXT_PUBLIC_RPC_URL=https://sepolia.unichain.org
NEXT_PUBLIC_HOOK_ADDRESS=0x...                  # LambdaHook
NEXT_PUBLIC_FUNDING_ADDRESS=0x...               # Funding
NEXT_PUBLIC_POOL_ID=0x...                        # poolId (printed by DeployUnichain)

# Pool tokens + the configured range (front-end converts amounts <-> liquidity).
NEXT_PUBLIC_TOKEN0=0x...
NEXT_PUBLIC_TOKEN1=0x...
NEXT_PUBLIC_TOKEN0_SYMBOL=WETH
NEXT_PUBLIC_TOKEN1_SYMBOL=USDC
NEXT_PUBLIC_TOKEN0_DECIMALS=18
NEXT_PUBLIC_TOKEN1_DECIMALS=6
